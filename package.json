    "code-blocks",
    "typescript"
  ],
  "type": "module",
  "exports": "./src/index.js",
  "bin": {
    "readme-assert": "./src/cli.js"
  },
  "files": [
    "src"
  ],
  "license": "MIT",
  "author": {
    "name": "Sigurd Fosseng",
