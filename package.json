{
  "name": "readme-assert",
  "version": "10.1.3",
  "description": "Run code blocks in your readme as tests",
  "keywords": [
    "readme",
    "test",
    "testing",
    "documentation",
    "doctest",
    "assert",
    "markdown",
    "code-blocks",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "readme-assert": "bin.js"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "license": "MIT",
  "author": {
    "name": "Sigurd Fosseng",
    "email": "sigurd@fosseng.net",
    "url": "https://laat.dev"
  },
  "homepage": "https://readme-assert.laat.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laat/readme-assert.git"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "esrap": "^2.2.5",
    "oxc-parser": "^0.128.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.ts && node src/cli.ts",
    "test:examples": "pnpm -r test",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
