    "url": "http://laat.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/laat/readme-assert.git"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "esbuild": "^0.27.0",
    "magic-string": "^0.30.0",
    "oxc-parser": "^0.123.0"
  },
